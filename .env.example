# Sarathi AI — fully local (no cloud API keys)

APP_NAME="Sarathi AI"
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_PREFIX=/api/v1
API_PORT=8000

# Security / JWT
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_USER=sarathi
POSTGRES_PASSWORD=sarathi
POSTGRES_DB=sarathi
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sarathi:sarathi@localhost:5432/sarathi

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=gita_verses_local
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Local LLM via Ollama (Gemma 4)
# Install models:
#   ollama pull gemma4:12b
#   ollama pull nomic-embed-text
# Requires Ollama >= 0.20 (Gemma 4). If system Ollama is older, run a
# user-local build on another port, e.g. OLLAMA_HOST=127.0.0.1:11435
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11435
OLLAMA_CHAT_MODEL=gemma4:12b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=180
EMBEDDING_DIMENSIONS=768

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Long-term vector memory (career goals, journals, favorites, summaries)
MEMORY_ENABLED=true
MEMORY_QDRANT_COLLECTION=user_memory_local
MEMORY_RECALL_TOP_K=6

# Retrieval / RAG
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_POOL=30
RETRIEVAL_BM25_TOP_K=20
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_RRF_K=60
RETRIEVAL_MIN_RERANK_SCORE=-10.0
RETRIEVAL_QUERY_EXPANSION=true
RERANKER_BACKEND=lexical
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Voice mode (local Whisper + Piper)
VOICE_ENABLED=true
VOICE_WARMUP_ON_STARTUP=true
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en
PIPER_MODEL_PATH=~/.local/share/sarathi/piper/en_US-lessac-medium.onnx
